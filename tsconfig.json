{
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["node", "vite/client"],
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"allowJs": true,
		"baseUrl": ".",
		"esModuleInterop": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": [
		"src/**/*"
	]
}
